<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="32dp">

        <!-- Título editorial grande -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RE&amp;"
            android:textSize="80sp"
            android:textColor="@color/primary"
            android:fontFamily="@font/unbounded_black"
            android:letterSpacing="-0.03"
            android:lineSpacingMultiplier="0.85"
            android:layout_marginTop="40dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="acci\u00f3n"
            android:textSize="64sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/playfair_display"
            android:textStyle="italic"
            android:letterSpacing="-0.02"
            android:layout_marginTop="-12dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DESAF\u00cdO DE REACCI\u00d3N Y ATENCI\u00d3N"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/dm_mono"
            android:letterSpacing="0.15"
            android:layout_marginBottom="40dp" />

        <!-- Nombre del jugador -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre del jugador"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/text_secondary"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_player_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/dm_mono"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Modo de juego -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Modo de juego"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/text_secondary"
            android:layout_marginBottom="20dp">

            <AutoCompleteTextView
                android:id="@+id/actv_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/dm_mono"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Iteraciones por nivel -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Iteraciones por nivel"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/text_secondary"
            android:layout_marginBottom="28dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_iterations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/dm_mono"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Tiempo máximo de reacción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TIEMPO M\u00c1XIMO"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/dm_mono"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tv_time_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="28sp"
                android:fontFamily="@font/unbounded_black" />

        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="1"
            android:valueTo="30"
            android:stepSize="1"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary"
            app:trackColorInactive="@color/surface"
            app:haloColor="@color/primary_container"
            android:layout_marginBottom="40dp" />

        <!-- Botón JUGAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="JUGAR \u2192"
            android:textSize="18sp"
            android:textColor="@color/on_primary"
            android:fontFamily="@font/unbounded_black"
            android:letterSpacing="0.05"
            app:backgroundTint="@color/primary" />

    </LinearLayout>
</ScrollView>

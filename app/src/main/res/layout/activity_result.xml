<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="20dp">

        <!-- Pill de estado -->
        <TextView
            android:id="@+id/tv_result_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/pill_gameover"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="&#10005; GAME OVER"
            android:textSize="11sp"
            android:textColor="#FB923C"
            android:fontFamily="@font/unbounded"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp" />

        <!-- Estado grande -->
        <TextView
            android:id="@+id/tv_result_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GAME OVER"
            android:textSize="36sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/unbounded_black"
            android:letterSpacing="-0.02"
            android:lineSpacingMultiplier="0.88"
            android:layout_marginBottom="2dp" />

        <!-- Jugador / Modo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_result_player"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/dm_mono" />

            <TextView
                android:id="@+id/tv_result_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/secondary"
                android:fontFamily="@font/dm_mono"
                android:letterSpacing="0.08" />

        </LinearLayout>

        <!-- Banner de nuevo récord -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_record"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/secondary_container"
            app:cardCornerRadius="6dp"
            app:strokeColor="@color/secondary"
            app:strokeWidth="1dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NUEVO R\u00c9CORD PERSONAL"
                android:textColor="@color/secondary"
                android:textSize="13sp"
                android:fontFamily="@font/dm_mono"
                android:letterSpacing="0.1"
                android:gravity="center"
                android:padding="14dp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Puntos editorial: número grande (Unbounded) + "puntos" (Playfair) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_result_points"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="96sp"
                android:textColor="@color/primary"
                android:fontFamily="@font/unbounded_black"
                android:letterSpacing="-0.03"
                android:lineSpacingMultiplier="0.85" />

            <TextView
                android:id="@+id/tv_puntos_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" puntos"
                android:textSize="28sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/playfair_display"
                android:textStyle="italic"
                android:layout_marginBottom="18dp" />

        </LinearLayout>

        <!-- Tres tarjetas de stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Tiempo promedio -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="10dp"
                app:strokeColor="@color/primary_container"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PROMEDIO"
                        android:textSize="9sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/dm_mono"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_stat_avg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="— ms"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/unbounded_black" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Niveles completados -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="10dp"
                app:strokeColor="@color/primary_container"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NIVEL"
                        android:textSize="9sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/dm_mono"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_stat_level"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1 / 3"
                        android:textSize="20sp"
                        android:textColor="@color/secondary"
                        android:fontFamily="@font/unbounded_black" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Respuestas correctas (tarjeta full-width) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="10dp"
            app:strokeColor="@color/primary_container"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="RESPUESTAS CORRECTAS"
                        android:textSize="9sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/dm_mono"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_stat_correct"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textColor="@color/correct"
                        android:fontFamily="@font/unbounded_black" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_stat_times"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/dm_mono"
                    android:gravity="end" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- JUGAR DE NUEVO -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_restart"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="JUGAR DE NUEVO"
            android:textColor="@color/on_primary"
            android:fontFamily="@font/unbounded_black"
            android:textSize="16sp"
            android:letterSpacing="0.04"
            app:backgroundTint="@color/primary"
            android:layout_marginBottom="12dp" />

        <!-- ver estadísticas -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_stats"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="ver estad\u00edsticas"
            android:textColor="@color/primary"
            android:fontFamily="@font/playfair_display"
            android:textStyle="italic"
            android:textSize="15sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:backgroundTint="@color/surface"
            app:strokeColor="@color/primary_container" />

    </LinearLayout>
</ScrollView>

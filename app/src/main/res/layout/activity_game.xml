<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0D0A"
    android:keepScreenOn="true">

    <!-- Barra de tiempo: FrameLayout contenedor (ancho fijo = pantalla),
         View interior cuyo ancho cambia desde Java -->
    <FrameLayout
        android:id="@+id/time_bar_container"
        android:layout_width="0dp"
        android:layout_height="3dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/view_time_bar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#4ADE80" />

    </FrameLayout>

    <!-- Header flotante: puntos (izquierda) -->
    <TextView
        android:id="@+id/tv_points_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 pts"
        android:textSize="9sp"
        android:fontFamily="@font/dm_mono"
        android:textColor="#80F5EED8"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/time_bar_container"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Header flotante: nivel pill (derecha) -->
    <TextView
        android:id="@+id/tv_pill_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/pill_hud"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="&#9658; NVL 01/03"
        android:textSize="7sp"
        android:fontFamily="@font/unbounded"
        android:textColor="#A855F7"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/time_bar_container"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Regla activa -->
    <TextView
        android:id="@+id/tv_rule"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:fontFamily="@font/dm_mono"
        android:textColor="#F5EED8"
        android:alpha="0.7"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="2dp"
        app:layout_constraintTop_toBottomOf="@id/tv_points_info"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Zona del estímulo -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/stimulus_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="#2E2A22"
        app:rippleColor="@android:color/transparent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_rule"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_iteration_info">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Texto del estímulo con autoSize -->
            <TextView
                android:id="@+id/tv_stimulus"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:gravity="center"
                android:padding="24dp"
                android:maxLines="1"
                android:hyphenationFrequency="none"
                android:breakStrategy="simple"
                android:text=""
                android:textColor="#F5EED8"
                android:fontFamily="@font/unbounded_black"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeMaxTextSize="64sp"
                app:autoSizeStepGranularity="2sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/tv_instruction" />

            <!-- Instrucción dentro del recuadro -->
            <TextView
                android:id="@+id/tv_instruction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="8sp"
                android:fontFamily="@font/dm_mono"
                android:gravity="center"
                android:paddingBottom="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Footer: etiqueta RONDA -->
    <TextView
        android:id="@+id/tv_iteration_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="RONDA 01 / 20"
        android:textSize="7sp"
        android:fontFamily="@font/dm_mono"
        android:textColor="#40F5EED8"
        android:gravity="center"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/progress_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Footer: barra de progreso -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0"
        app:trackThickness="2dp"
        app:indicatorColor="#4ADE80"
        app:trackColor="#1A1712"
        app:trackCornerRadius="2dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btn_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Footer: dos botones de opción lado a lado -->
    <LinearLayout
        android:id="@+id/btn_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_option_a"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="9sp"
            android:textColor="#D4FF00"
            android:fontFamily="@font/unbounded"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginEnd="6dp"
            app:strokeColor="#D4FF00"
            app:strokeWidth="1.5dp"
            app:cornerRadius="10dp"
            app:backgroundTint="@android:color/transparent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_option_b"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="9sp"
            android:textColor="#D4FF00"
            android:fontFamily="@font/unbounded"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginStart="6dp"
            app:strokeColor="#D4FF00"
            app:strokeWidth="1.5dp"
            app:cornerRadius="10dp"
            app:backgroundTint="@android:color/transparent" />

    </LinearLayout>

    <!-- Overlay de estado: cubre toda la pantalla -->
    <FrameLayout
        android:id="@+id/overlay_status"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#E60F0D0A"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_overlay_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:fontFamily="@font/unbounded"
                android:textSize="13sp"
                android:text="" />

            <TextView
                android:id="@+id/tv_overlay_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/dm_mono"
                android:textSize="10sp"
                android:gravity="center"
                android:visibility="gone"
                android:text="" />

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
